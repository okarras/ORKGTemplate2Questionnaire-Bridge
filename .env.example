# Required for ScidQuest AI features (suggestions, answer verification)
# Get your API key from https://platform.openai.com/api-keys
# Copy this file to .env.local and set your key. Restart the dev server after changing.
OPENAI_API_KEY=sk-...

# ORKG Sandbox — no env variable needed.
# The sandbox URL (https://sandbox.orkg.org/api) is hardcoded in the API routes.
# Users supply their sandbox credentials at submission time via the in-app modal.
# Register a free sandbox account at: https://sandbox.orkg.org/sign-up
